        "react-dom": "^19.2.5",
        "react-hook-form": "^7.73.1",
        "rollup": "^4.60.2",
        "rollup-plugin-dts": "^6.4.1",
        "rollup-plugin-peer-deps-external": "^2.2.4",
        "storybook": "^10.3.5",
